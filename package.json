{
  "name": "fluid-level-background-card",
  "version": "0.3.0-beta1",
  "description": "Lovelace fluid-level-background-card",
  "type": "module",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards"
  ],
  "module": "fluid-level-background-card.js",
  "repository": "git@github.com:custom_cards/fluid-level-background-card.git",
  "author": "Ian Richardson <iantrich@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "colortranslator": "^6.1.1",
    "custom-card-helpers": "^2.0.0",
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@digitalroute/cz-conventional-changelog-for-jira": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.4",
    "cz": "^1.8.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-prettier": "^5.5.6",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "rollup-plugin-serve": "^3.0.0",
    "rollup-plugin-summary": "^3.0.0",
    "rollup-plugin-typescript2": "^0.37.0",
    "ts-lit-plugin": "^2.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.10"
  },
  "scripts": {
    "start": "rollup -c rollup.config.js --watch",
    "build": "npm run lint && npm run rollup",
    "lint": "eslint src/*.ts",
    "rollup": "rollup -c",
    "prepare": "husky install",
    "commit": "cz",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "test:sonar": "npm run test:coverage",
    "test:setup": "scripts/test-setup"
  },
  "lint-staged": {
    "*.js": [
      "eslint",
      "prettier --write"
    ]
  }
}
